  document.getElementById('cfg-status').textContent = 'Settings saved.';
  setTimeout(()=>document.getElementById('cfg-status').textContent='',2000);
}
async function testBackend() {
  document.getElementById('cfg-status').textContent = 'Testing...';
  try {
    const r = await fetch(`${CFG.url}/healthz`);
    const d = await r.json();
    document.getElementById('cfg-status').textContent = d.status === 'ok' ? '✓ Backend healthy' : 'Unexpected response';
  } catch(e) {
    document.getElementById('cfg-status').textContent = '✗ Connection failed — check URL';
    document.getElementById('cfg-status').className = 'status-msg err';
