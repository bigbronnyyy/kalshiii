<script>
// ── Config (loaded from localStorage) ──────────────────
let CFG = {
  url: 'https://kalshiii-production.up.railway.app',
  key: 'super_random_password_12345678910',
  kelly: 0.25,
  evThresh: 0.05,
  minEv: 3
};
function loadCfg() {
  const s = localStorage.getItem('kqb_cfg');
  if (s) try { CFG = {...CFG, ...JSON.parse(s)}; } catch(e){}
