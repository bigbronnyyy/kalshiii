}

// ── Evidence config ─────────────────────────────────────
const EV_CFG = {
  mom1:{delta:0.09,dir:'bull'}, mom2:{delta:-0.09,dir:'bear'},
  mom3:{delta:0.00,dir:'neut'}, mom4:{delta:0.05,dir:'bull'},
  mom5:{delta:0.12,dir:'bull'}, mom6:{delta:-0.12,dir:'bear'},
  mac1:{delta:0.08,dir:'bull'}, mac2:{delta:-0.08,dir:'bear'},
  mac3:{delta:-0.04,dir:'bear'},mac4:{delta:-0.05,dir:'bear'},
  mac5:{delta:0.03,dir:'bull'}, mac6:{delta:0.06,dir:'bull'},
  str1:{delta:-0.05,dir:'bear'},str2:{delta:0.07,dir:'bull'},
  str3:{delta:-0.07,dir:'bear'},str4:{delta:0.04,dir:'bull'},
  str5:{delta:-0.03,dir:'bear'},str6:{delta:0.05,dir:'bull'},
  sen1:{delta:-0.06,dir:'bear'},sen2:{delta:0.05,dir:'bull'},
  sen3:{delta:0.04,dir:'bull'}, sen4:{delta:-0.03,dir:'bear'},
  sen5:{delta:-0.03,dir:'bear'},sen6:{delta:-0.04,dir:'bear'}
};
const evState = {};

function tog(id) {
  const btn = document.getElementById('tog-'+id);
  const cfg = EV_CFG[id];
  evState[id] = evState[id] ? null : true;
  if (evState[id]) {
    btn.className = 'ev-tog ' + (cfg.delta >= 0 ? 'on-bull' : 'on-bear');
    btn.textContent = cfg.delta > 0 ? '↑' : cfg.delta < 0 ? '↓' : '–';
  } else {
    btn.className = 'ev-tog off'; btn.textContent = '—';
  }
  calcProb();
}

function resetEvidence() {
  Object.keys(EV_CFG).forEach(id => {
    evState[id] = null;
    const btn = document.getElementById('tog-'+id);
    if (btn) { btn.className='ev-tog off'; btn.textContent='—'; }
  });
  calcProb();
}

// ── Probability calculation ─────────────────────────────
function logit(p){return Math.log(p/(1-p))}
function sigmoid(x){return 1/(1+Math.exp(-x))}
function clamp(p){return Math.min(0.96,Math.max(0.04,p))}

function calcProb() {
  const baseOverride = parseFloat(document.getElementById('base-override').value);
  const base = isNaN(baseOverride) ? 0.50 : clamp(baseOverride/100);
  const active = Object.entries(evState).filter(([,v])=>v).map(([id])=>({id,cfg:EV_CFG[id]}));
  const activeCount = active.length;

  // Logit-space Bayesian updating
  let logitP = logit(base);
  const chain = [{label:`Prior: ${(base*100).toFixed(0)}%`, cls:'start', p: base}];
  active.forEach(({id,cfg}) => {
    if (cfg.delta === 0) return;
    logitP += cfg.delta * 2.2;
    const p = clamp(sigmoid(logitP));
    const sign = cfg.delta > 0 ? '+' : '';
    chain.push({
      label:`${sign}${(cfg.delta*100).toFixed(0)}% → ${(p*100).toFixed(0)}%`,
      cls: cfg.delta > 0 ? 'bull' : 'bear', p
    });
  });

  const posterior = clamp(sigmoid(logitP));
  const totalAdj = logitP - logit(base);

  // Override check
  const override = parseFloat(document.getElementById('p-override').value);
  const modelP = !isNaN(override) && override > 0 ? clamp(override/100) : posterior;

  // Update displays
  document.getElementById('pd-prior').textContent = (base*100).toFixed(0)+'%';
  document.getElementById('pd-adj').textContent = (totalAdj >= 0 ? '+' : '') + (totalAdj*100).toFixed(0)+'% logit';
  document.getElementById('pd-post').textContent = (posterior*100).toFixed(0)+'%';
  document.getElementById('pd-model').textContent = (modelP*100).toFixed(0)+'%';

  // Build bayes chain visual
  const bcEl = document.getElementById('bc');
  let html = '';
  chain.forEach((s,i)=>{
    html += `<span class="bc-step ${s.cls}">${s.label}</span>`;
    if (i < chain.length-1) html += '<span class="bc-arr">→</span>';
  });
  html += `<span class="bc-arr">→</span><span class="bc-step fin">Model: ${(modelP*100).toFixed(0)}%</span>`;
  bcEl.innerHTML = html;

  // Warnings
  const sampleWarn = document.getElementById('warn-sample');
  sampleWarn.className = 'warn-box' + (activeCount < CFG.minEv && activeCount > 0 ? ' on' : '');

  // Check for correlations (macro bear + sentiment bear = correlated)
  const hasMacroBear = evState['mac2'] || evState['mac4'];
  const hasSentBear = evState['sen1'] || evState['sen5'];
  const hasMomentumBull = evState['mom1'] || evState['mom5'];
  const hasStrBull = evState['str2'] || evState['str6'];
  const corrWarn = document.getElementById('warn-corr');
  const correlated = (hasMacroBear && hasSentBear) || (hasMomentumBull && hasStrBull && evState['mac6']);
  corrWarn.className = 'warn-box' + (correlated ? ' on' : '');

  return { base, posterior, modelP, activeCount, active };
}

// ── Math helpers ────────────────────────────────────────
function evCalc(mp,pp){return (mp-pp)/pp}
function evSig(e,thresh){return e>thresh?'BUY':e<-thresh?'SELL':'SKIP'}
function kellyCalc(p,pp,f){
  const b=(1-pp)/pp,q=1-p,full=(p*b-q)/b;
  return{full,scaled:Math.max(full,0)*f};
}

// ── Auto-fetch ticker ───────────────────────────────────
let fetchTimer=null, cachedMkt=null;
function onTickerInput(){
  clearTimeout(fetchTimer);
  const q = document.getElementById('market-q').value.trim().toUpperCase();
  if(q.length>10&&q.includes('-')&&!q.includes(' ')){
    setDot('spin','fetching live data...');
    fetchTimer=setTimeout(()=>autoFetch(q),750);
  } else {
    setDot('','enter ticker to auto-fetch');
    document.getElementById('live-prev').classList.remove('on');
    cachedMkt=null;
  }
}
async function autoFetch(ticker){
  try{
    const r=await fetch(`${CFG.url}/market/${encodeURIComponent(ticker)}`,{headers:{'x-proxy-api-key':CFG.key}});
    if(!r.ok) throw new Error();
    const d=await r.json(); if(!d.market) throw new Error();
    cachedMkt=d.market; const m=cachedMkt;
    const raw=m.last_price_dollars??m.yes_ask_dollars??m.yes_bid_dollars??null;
    if(raw&&parseFloat(raw)>0) document.getElementById('mkt-price').value=Math.round(parseFloat(raw)*100);
    if(!document.getElementById('res-date').value&&m.close_time)
      document.getElementById('res-date').value=new Date(m.close_time).toLocaleString();
    document.getElementById('lp-price').textContent=raw?'$'+raw:'—';
    document.getElementById('lp-ask').textContent=m.yes_ask_dollars?'$'+m.yes_ask_dollars:'—';
    document.getElementById('lp-bid').textContent=m.yes_bid_dollars?'$'+m.yes_bid_dollars:'—';
    document.getElementById('lp-strike').textContent=m.floor_strike?'$'+Number(m.floor_strike).toLocaleString():'—';
    document.getElementById('live-prev').classList.add('on');
    setDot('ok',`live · ${m.subtitle||ticker} · ${m.status}`);
  } catch(e){
    setDot('fail','ticker not found — enter price manually');
    document.getElementById('live-prev').classList.remove('on');
    cachedMkt=null;
  }
}
function setDot(s,t){
  document.getElementById('adot').className='adot'+(s?' '+s:'');
