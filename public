    const d=await r.json();
    const mkts=(d.markets||[]).filter(m=>m.status!=='finalized').slice(0,15);
    if(!mkts.length){list.innerHTML='<div style="font-size:11px;color:var(--text3);padding:8px">No active markets found for '+s+'</div>';return;}
    list.innerHTML=mkts.map(m=>{
