// ── Main analysis ───────────────────────────────────────
async function runAnalysis(){
  const q=document.getElementById('market-q').value.trim();
  const priceCents=parseFloat(document.getElementById('mkt-price').value);
  const bankroll=parseFloat(document.getElementById('bankroll').value)||null;
  const resDate=document.getElementById('res-date').value.trim();
  const kf=parseFloat(document.getElementById('kelly-f').value);
  const ctx=document.getElementById('ctx').value.trim();

  if(!q){setStatus('Enter a ticker or market.',true);return;}
  if(!priceCents||isNaN(priceCents)){setStatus('Market price needed — browse or enter manually.',true);return;}

  const {base,posterior,modelP,activeCount,active}=calcProb();

  const activeLabels = {
    mom1:'trending toward strike',mom2:'trending away from strike',
    mom3:'within 0.5% of strike',mom4:'strong volume',
    mom5:'price >2% above strike',mom6:'price >2% below strike',
    mac1:'bullish catalyst',mac2:'bearish catalyst/FOMC',
    mac3:'options expiry nearby',mac4:'FOMC uncertainty',
    mac5:'no major catalysts',mac6:'positive institutional flow',
    str1:'round number resistance',str2:'broke above strike',
    str3:'rejection at strike',str4:'strong support below',
    str5:'OI bias at strike',str6:'breakout from consolidation',
    sen1:'extreme fear (F&G<25)',sen2:'greed/neutral sentiment',
    sen3:'resolution <6h',sen4:'resolution >24h',
    sen5:'correlating with equities',sen6:'consensus already priced'
  };
  const evidenceSummary = active.map(({id})=>activeLabels[id]||id).join('; ') || 'none selected';

  setStatus('');
  document.getElementById('results').classList.remove('on');
  document.getElementById('loading').classList.add('on');
  document.getElementById('run-btn').disabled=true;

  // Try live fetch if not cached
  if(!cachedMkt){
    const isTicker=q.length>8&&!q.includes(' ')&&q.includes('-');
    if(isTicker){
      setLoad('FETCHING LIVE KALSHI DATA...');
      try{
        const r=await fetch(`${CFG.url}/market/${encodeURIComponent(q.toUpperCase())}`,{headers:{'x-proxy-api-key':CFG.key}});
        if(r.ok){const d=await r.json();cachedMkt=d.market||null;}
      }catch(e){}
    }
  }

  const mktP=priceCents/100;
  const evVal=evCalc(modelP,mktP);
  const evS=evSig(evVal,CFG.evThresh);
  const k=kellyCalc(modelP,mktP,kf);
  const usedLive=!!cachedMkt;

  setLoad('RUNNING BASE RATES · BAYES · EV · KELLY · CORRELATIONS...');

  const liveInfo=cachedMkt?`Live Kalshi data: ticker=${cachedMkt.ticker}, strike=$${cachedMkt.floor_strike}, last=${cachedMkt.last_price_dollars}, yes_ask=${cachedMkt.yes_ask_dollars}, yes_bid=${cachedMkt.yes_bid_dollars}, status=${cachedMkt.status}, closes=${cachedMkt.close_time}, rule: "${cachedMkt.rules_primary}"`:'' ;

  const prompt=`You are a strict quantitative prediction market analyst. Return ONLY valid JSON, no markdown, no preamble.

FRAMEWORK:
1. Use base rates to establish prior probabilities
2. Apply Bayesian updating sequentially for each piece of evidence
3. Calculate EV for both YES and NO sides
4. Apply Kelly criterion for position sizing
5. Check for hidden correlations and confounders between signals
6. Account for sample size before drawing conclusions
7. Execute decisively — give a clear BUY, SELL, or SKIP

MARKET: ${q}
Market implied probability: ${(mktP*100).toFixed(1)}%
Base rate prior: ${(base*100).toFixed(0)}%
Bayesian posterior (from ${activeCount} evidence signals): ${(posterior*100).toFixed(0)}%
Final model probability: ${(modelP*100).toFixed(1)}%
Evidence signals active: ${evidenceSummary}
Context: ${ctx||'none provided'}
${liveInfo}
Resolution: ${resDate||'not specified'}
Bankroll: ${bankroll?'$'+bankroll:'not provided'}
Kelly fraction: ${kf}x
EV threshold: ${(CFG.evThresh*100).toFixed(0)}%
Evidence count: ${activeCount} signals (min for HIGH confidence: ${CFG.minEv})

Pre-computed math:
- EV: ${(evVal*100).toFixed(2)}% → ${evS}
- Full Kelly: ${(k.full*100).toFixed(2)}%
- Scaled Kelly (${kf}x): ${(k.scaled*100).toFixed(2)}%
- EV for NO side: ${(evCalc(1-modelP,1-mktP)*100).toFixed(2)}%

Today is March 17 2026. Current BTC ~$74,500. FOMC March 18-19. Quadruple witching + BTC options expiry March 20.

Return exactly this JSON:
{
  "signal": "BUY" or "SELL" or "SKIP",
  "confidence": "HIGH" or "MEDIUM" or "LOW",
  "confidence_reason": "one sentence on why this confidence level",
  "verdict": "2-3 sentence executive summary of the signal and reasoning",
  "base_rate_used": 0.5,
  "base_rate_class": "description of reference class",
  "base_rate_rationale": "why this base rate applies",
  "bayes_prior": 0.5,
  "bayes_posterior": 0.5,
  "bayes_key_mover": "which single piece of evidence most changed the posterior and why",
  "bayes_summary": "2-3 sentences explaining the full evidence chain",
  "ev_yes": ${(evVal*100).toFixed(2)},
  "ev_no": ${(evCalc(1-modelP,1-mktP)*100).toFixed(2)},
  "ev_interpretation": "one sentence on what the EV numbers mean for this trade",
  "kelly_full_pct": ${(k.full*100).toFixed(2)},
  "kelly_scaled_pct": ${(k.scaled*100).toFixed(2)},
  "kelly_rationale": "one sentence on sizing discipline",
  "correlations": [
    {"signal": "signal name", "correlated_with": "other signal", "impact": "brief description of double-counting risk"}
  ],
  "confounders": ["confounder 1", "confounder 2"],
  "sample_size_note": "assessment of whether evidence count is sufficient",
  "trade_plan": "3-4 sentences: entry zone, what confirms the trade, what invalidates it, what to watch",
  "risks": ["risk 1", "risk 2", "risk 3", "BIGGEST RISK: description"],
  "bottom_line": "one sharp actionable sentence with specific price or probability threshold"
}`;

  try{
    setLoad('COMPUTING SIGNAL...');
    const res=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1500,
        messages:[{role:'user',content:prompt}]
      })
    });
    const data=await res.json();
    const txt=(data.content||[]).map(b=>b.text||'').join('');
    let parsed;
    try{parsed=JSON.parse(txt.replace(/```json|```/g,'').trim());}
    catch(e){
      document.getElementById('loading').classList.remove('on');
      document.getElementById('run-btn').disabled=false;
      setStatus('Parse error — try again.',true);
      return;
    }
    renderResults(parsed,mktP,modelP,base,bankroll,kf,usedLive,evVal,evS,k,activeCount);
  } catch(e){
    document.getElementById('loading').classList.remove('on');
    document.getElementById('run-btn').disabled=false;
    setStatus('API error — check connection.',true);
  }
}

// ── Render ──────────────────────────────────────────────
let lastResult=null;
function renderResults(p,mktP,modelP,base,bankroll,kf,usedLive,evVal,evS,k,evidenceCount){
  document.getElementById('loading').classList.remove('on');
  document.getElementById('run-btn').disabled=false;

  const sig=p.signal||evS;
  const sb=document.getElementById('r-sig');
  sb.textContent=sig;
  sb.className='sig '+(sig==='BUY'?'sig-buy':sig==='SELL'?'sig-sell':'sig-skip');

  document.getElementById('r-conf').textContent=(p.confidence||'MEDIUM')+' CONF';
  const lt=document.getElementById('r-live'); lt.className='badge live'+(usedLive?' on':'');
  document.getElementById('r-verdict').textContent=p.verdict||'';

  // Metrics
  const evEl=document.getElementById('r-ev');
  evEl.textContent=(evVal>=0?'+':'')+(evVal*100).toFixed(1)+'%';
  evEl.className='m-val '+(evS==='BUY'?'green':evS==='SELL'?'red':'');
  document.getElementById('r-evsig').textContent='signal: '+evS;

  document.getElementById('r-prior').textContent=(base*100).toFixed(0)+'%';
  document.getElementById('r-model').textContent=(modelP*100).toFixed(0)+'%';
  document.getElementById('r-mkt').textContent='market: '+(mktP*100).toFixed(0)+'%';

  const kEl=document.getElementById('r-kelly');
  kEl.textContent=(k.scaled*100).toFixed(1)+'%';
  kEl.className='m-val '+(k.scaled>0?'green':'');
  document.getElementById('r-kellysub').textContent='full: '+(k.full*100).toFixed(1)+'%';

  const posEl=document.getElementById('r-pos');
  if(bankroll&&k.scaled>0){
    posEl.textContent='$'+(bankroll*k.scaled).toFixed(0);
    posEl.className='m-val green';
    document.getElementById('r-possub').textContent='of $'+bankroll;
  } else if(k.scaled<=0){
    posEl.textContent='$0'; posEl.className='m-val';
    document.getElementById('r-possub').textContent='no edge — skip';
  } else {
    posEl.textContent='—'; posEl.className='m-val';
    document.getElementById('r-possub').textContent='add bankroll';
  }

  const confEl=document.getElementById('r-confval');
  confEl.textContent=p.confidence||'—';
  confEl.className='m-val purple';
  document.getElementById('r-confsub').textContent=p.confidence_reason||'';

  // Bayes
  document.getElementById('r-bayes').innerHTML=`
    <div class="dr"><span class="dl">Base rate used</span><span class="dv">${((p.base_rate_used||base)*100).toFixed(0)}%</span></div>
    <div class="dr"><span class="dl">Key mover</span><span class="dv" style="font-size:10px;max-width:170px;text-align:right">${p.bayes_key_mover||'—'}</span></div>
    <div class="dr"><span class="dl">Posterior</span><span class="dv">${((p.bayes_posterior||modelP)*100).toFixed(0)}%</span></div>
    <div class="dr"><span class="dl">Evidence signals</span><span class="dv">${evidenceCount}</span></div>
    <div class="dc-text">${p.bayes_summary||''}</div>`;

  // Base rate
  document.getElementById('r-base').innerHTML=`
    <div class="dr"><span class="dl">Reference class</span><span class="dv" style="font-size:10px;max-width:160px;text-align:right">${p.base_rate_class||'—'}</span></div>
    <div class="dr"><span class="dl">Base rate</span><span class="dv">${((p.base_rate_used||base)*100).toFixed(0)}%</span></div>
    <div class="dr"><span class="dl">EV (YES)</span><span class="dv">${p.ev_yes!=null?(p.ev_yes>=0?'+':'')+p.ev_yes.toFixed(1)+'%':'—'}</span></div>
    <div class="dr"><span class="dl">EV (NO)</span><span class="dv">${p.ev_no!=null?(p.ev_no>=0?'+':'')+p.ev_no.toFixed(1)+'%':'—'}</span></div>
    <div class="dc-text">${p.base_rate_rationale||''}</div>`;

  document.getElementById('r-trade').innerHTML=(p.trade_plan||'—');

  document.getElementById('r-risks').innerHTML=(p.risks||[]).map(r=>`
    <div class="risk-item">
      <div class="rpip ${r.toUpperCase().startsWith('BIGGEST')?'crit':''}"></div>
      <span>${r}</span>
    </div>`).join('');

  // Correlations & confounders
  const corrHTML = [];
  if(p.correlations&&p.correlations.length){
    p.correlations.forEach(c=>{
      corrHTML.push(`<div class="corr-item">
        <div class="corr-lbl">Correlation</div>
        <div class="corr-val">${c.signal} ↔ ${c.correlated_with}</div>
        <div class="corr-flag warn">⚠ ${c.impact}</div></div>`);
    });
  }
  if(p.confounders&&p.confounders.length){
    p.confounders.forEach(c=>{
      corrHTML.push(`<div class="corr-item">
        <div class="corr-lbl">Confounder</div>
        <div class="corr-val">${c}</div>
        <div class="corr-flag warn">⚠ check before trading</div></div>`);
    });
  }
  if(p.sample_size_note){
    corrHTML.push(`<div class="corr-item">
      <div class="corr-lbl">Sample size</div>
      <div class="corr-val" style="font-size:11px">${p.sample_size_note}</div>
      <div class="corr-flag ${evidenceCount>=CFG.minEv?'ok':'warn'}">${evidenceCount>=CFG.minEv?'✓ sufficient':'⚠ low — treat as LOW confidence'}</div></div>`);
  }
  if(!corrHTML.length) corrHTML.push(`<div class="corr-item"><div class="corr-lbl">Status</div><div class="corr-val">No major correlations detected</div><div class="corr-flag ok">✓ clean</div></div>`);
  document.getElementById('r-corr').innerHTML=corrHTML.join('');

  document.getElementById('r-bottom').textContent=p.bottom_line||'';
  document.getElementById('results').classList.add('on');
  document.getElementById('results').scrollIntoView({behavior:'smooth',block:'start'});

  // Store for tracker
  lastResult={
    market: document.getElementById('market-q').value.trim(),
    signal: sig,
    modelP: (modelP*100).toFixed(0)+'%',
    mktP: (mktP*100).toFixed(0)+'%',
    ev: (evVal*100).toFixed(1)+'%',
    kelly: (k.scaled*100).toFixed(1)+'%',
    pos: bankroll&&k.scaled>0?'$'+(bankroll*k.scaled).toFixed(0):'—',
    confidence: p.confidence||'MEDIUM',
    bottom: p.bottom_line||'',
    date: new Date().toLocaleString(),
    result: 'open',
    pnl: 0
  };
}

// ── Trade Tracker ───────────────────────────────────────
function saveToTracker(){
  if(!lastResult) return;
  const trades=loadTrades();
  trades.unshift({...lastResult, id: Date.now()});
  localStorage.setItem('kqb_trades', JSON.stringify(trades));
  renderTracker();
  showTab('tracker');
}
function loadTrades(){
  try{return JSON.parse(localStorage.getItem('kqb_trades')||'[]');}catch(e){return[];}
}
function clearTracker(){
  if(confirm('Clear all trades?')){localStorage.removeItem('kqb_trades');renderTracker();}
}
function setOutcome(id, outcome, pnl){
  const trades=loadTrades();
  const t=trades.find(t=>t.id===id);
  if(t){t.result=outcome;t.pnl=parseFloat(pnl)||0;}
  localStorage.setItem('kqb_trades',JSON.stringify(trades));
  renderTracker();
}
function renderTracker(){
  const trades=loadTrades();
  const list=document.getElementById('trade-list');
  if(!trades.length){list.innerHTML='<div class="tracker-empty">No trades logged yet.</div>';updateStats([]);return;}

  list.innerHTML=trades.map(t=>`
    <div class="trade-row">
      <div class="t-market" title="${t.market}">${t.market.length>28?t.market.slice(0,28)+'…':t.market}</div>
      <div class="t-sig ${t.signal.toLowerCase()}">${t.signal}</div>
      <div style="color:var(--text2)">${t.modelP} model</div>
      <div style="color:var(--amber)">${t.ev} EV</div>
      <div class="t-result ${t.result}">${t.result==='open'?'OPEN':t.result==='win'?'WIN ✓':'LOSS ✗'}</div>
      <div style="display:flex;gap:4px">
        <button class="outcome-btn" onclick="markOutcome(${t.id},'win')">W</button>
        <button class="outcome-btn" onclick="markOutcome(${t.id},'loss')">L</button>
      </div>
    </div>`).join('');
  updateStats(trades);
}
function markOutcome(id, outcome){
  const pnl = outcome==='win' ? prompt('P&L amount ($):') || 0 : prompt('Loss amount ($, negative ok):') || 0;
  setOutcome(id, outcome, pnl);
}
function updateStats(trades){
  const closed=trades.filter(t=>t.result!=='open');
  const wins=closed.filter(t=>t.result==='win');
  const wr=closed.length?((wins.length/closed.length)*100).toFixed(0)+'%':'—';
  const totalPnl=closed.reduce((s,t)=>s+(parseFloat(t.pnl)||0),0);
  const avgEv=trades.length?(trades.reduce((s,t)=>s+parseFloat(t.ev),0)/trades.length).toFixed(1)+'%':'—';
  // Model accuracy: compare signal direction to outcome
  const calibrated=closed.filter(t=>(t.signal==='BUY'&&t.result==='win')||(t.signal==='SELL'&&t.result==='win')||(t.signal==='SKIP'));
  const acc=closed.length?((calibrated.length/closed.length)*100).toFixed(0)+'%':'—';

  document.getElementById('st-total').textContent=trades.length;
  document.getElementById('st-wr').textContent=wr;
  document.getElementById('st-ev').textContent=avgEv;
  const pnlEl=document.getElementById('st-pnl');
  pnlEl.textContent=closed.length?'$'+totalPnl.toFixed(0):'—';
  pnlEl.className='stat-val '+(totalPnl>0?'green':totalPnl<0?'red':'');
  document.getElementById('st-acc').textContent=acc;
}

// ── UI helpers ──────────────────────────────────────────
function showTab(name){
  ['analyze','tracker','settings'].forEach(t=>{
    document.getElementById('tab-'+t).style.display=t===name?'block':'none';
    document.querySelectorAll('.tab').forEach((el,i)=>{
      const names=['analyze','tracker','settings'];
      el.className='tab'+(names[i]===name?' active':'');
    });
  });
  if(name==='tracker') renderTracker();
}
function setStatus(msg,err){
  const el=document.getElementById('status-msg');
  el.textContent=msg; el.className='status-msg'+(err?' err':'');
}
function setLoad(msg){document.getElementById('load-txt').textContent=msg;}

// ── Init ────────────────────────────────────────────────
loadCfg();
calcProb();
renderTracker();
</script>
</body>
</html>
