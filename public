<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kalshi Quant Bot</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg0: #07080a;
  --bg1: #0d0f13;
  --bg2: #13161c;
  --bg3: #1a1e27;
  --bg4: #222634;
  --border: rgba(255,255,255,0.07);
  --border2: rgba(255,255,255,0.13);
  --text: #dde1ec;
  --text2: #7d8499;
  --text3: #3f4357;
  --green: #00e07a;
  --green2: rgba(0,224,122,0.12);
  --green3: rgba(0,224,122,0.06);
  --red: #ff4560;
  --red2: rgba(255,69,96,0.12);
  --amber: #ffb830;
  --amber2: rgba(255,184,48,0.12);
  --blue: #4dabf7;
  --blue2: rgba(77,171,247,0.12);
  --purple: #c084fc;
  --purple2: rgba(192,132,252,0.12);
  --mono: 'JetBrains Mono', monospace;
  --head: 'Syne', sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg0);color:var(--text);font-family:var(--mono);min-height:100vh;font-size:13px}

/* Noise texture overlay */
body::after{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");pointer-events:none;z-index:9999;opacity:0.4}

.wrap{max-width:980px;margin:0 auto;padding:2rem 1.25rem 6rem}

/* ── Header ── */
.hdr{display:flex;align-items:flex-start;justify-content:space-between;padding-bottom:1.5rem;margin-bottom:1.75rem;border-bottom:1px solid var(--border)}
.hdr-left h1{font-family:var(--head);font-size:26px;font-weight:800;color:var(--green);letter-spacing:-1px;line-height:1}
.hdr-left p{font-size:10px;color:var(--text3);margin-top:5px;letter-spacing:0.12em;text-transform:uppercase}
.pipe{display:flex;align-items:center;gap:4px;font-size:10px}
.ps{padding:3px 9px;border:1px solid var(--green);border-radius:2px;color:var(--green);letter-spacing:0.06em}
.pa{color:var(--text3)}

/* ── Tabs ── */
.tabs{display:flex;gap:2px;margin-bottom:1rem;border-bottom:1px solid var(--border)}
.tab{padding:8px 16px;font-family:var(--mono);font-size:11px;color:var(--text3);cursor:pointer;border-bottom:2px solid transparent;letter-spacing:0.06em;text-transform:uppercase;transition:color 0.15s}
.tab:hover{color:var(--text2)}
.tab.active{color:var(--green);border-bottom-color:var(--green)}

/* ── Panels ── */
.panel{background:var(--bg1);border:1px solid var(--border);border-radius:6px;padding:1.25rem;margin-bottom:.75rem}
.panel-lbl{font-size:9px;font-weight:700;letter-spacing:0.15em;color:var(--text3);text-transform:uppercase;margin-bottom:1rem}

/* ── Fields ── */
.fg{display:grid;gap:10px}
.fg2{grid-template-columns:1fr 1fr}
.fg3{grid-template-columns:1fr 1fr 1fr}
.fg4{grid-template-columns:1fr 1fr 1fr 1fr}
.fg1{grid-template-columns:1fr}
.field label{display:block;font-size:9px;color:var(--text3);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:5px}
.field input,.field select,.field textarea{width:100%;background:var(--bg2);border:1px solid var(--border);border-radius:3px;color:var(--text);font-family:var(--mono);font-size:12px;padding:8px 10px;outline:none;transition:border-color .15s;resize:vertical}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--green)}
.field input::placeholder,.field textarea::placeholder{color:var(--text3)}
.field select option{background:var(--bg2)}

/* ── Auto dot ── */
.adot-row{display:flex;align-items:center;gap:6px;font-size:10px;color:var(--text3);margin-top:5px}
.adot{width:5px;height:5px;border-radius:50%;background:var(--text3);flex-shrink:0}
.adot.spin{background:var(--amber);animation:blink .6s infinite}
.adot.ok{background:var(--green)}
.adot.fail{background:var(--red)}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}

/* ── Live preview ── */
.live-prev{display:none;background:var(--green3);border:1px solid rgba(0,224,122,0.15);border-radius:3px;padding:10px 12px;margin-top:8px}
.live-prev.on{display:block}
.lp-g{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}
.lp-l{font-size:9px;color:var(--green);opacity:.6;text-transform:uppercase;letter-spacing:.08em;margin-bottom:3px}
.lp-v{font-size:13px;font-weight:700;color:var(--green)}

/* ── Probability Engine ── */
.prob-engine{background:var(--bg1);border:1px solid var(--border2);border-radius:6px;padding:1.25rem;margin-bottom:.75rem}
.pe-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem}
.pe-title{font-family:var(--head);font-size:14px;font-weight:600;color:var(--blue)}
.pe-sub{font-size:10px;color:var(--text3);margin-top:2px;letter-spacing:.04em}

/* Evidence cards */
.ev-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}
.ev-card{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:10px 12px}
.ev-card-title{font-size:9px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px;padding-bottom:6px;border-bottom:1px solid var(--border)}
.ev-row{display:flex;align-items:center;gap:8px;padding:4px 0;cursor:pointer;border-radius:2px;transition:background .1s}
.ev-row:hover{background:rgba(255,255,255,.03)}
.ev-tog{width:22px;height:22px;border-radius:2px;border:1px solid var(--border2);background:transparent;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:11px;transition:all .1s;flex-shrink:0;font-family:var(--mono)}
.ev-tog.on-bull{border-color:var(--green);background:var(--green2);color:var(--green)}
.ev-tog.on-bear{border-color:var(--red);background:var(--red2);color:var(--red)}
.ev-tog.off{color:var(--text3)}
.ev-lbl{font-size:11px;color:var(--text2);flex:1;line-height:1.4}
.ev-wt{font-size:10px;color:var(--text3);flex-shrink:0}
.ev-wt.pos{color:rgba(0,224,122,.5)}
.ev-wt.neg{color:rgba(255,69,96,.5)}

/* Bayes chain */
.bc-wrap{margin-bottom:10px;overflow-x:auto;padding-bottom:4px}
.bc{display:flex;align-items:center;gap:3px;flex-wrap:wrap;row-gap:4px}
.bc-step{font-size:10px;padding:3px 8px;border-radius:2px;border:1px solid var(--border);color:var(--text3);white-space:nowrap}
.bc-step.start{color:var(--text2);border-color:var(--border2)}
.bc-step.bull{border-color:rgba(0,224,122,.3);color:var(--green);background:var(--green3)}
.bc-step.bear{border-color:rgba(255,69,96,.3);color:var(--red);background:var(--red2)}
.bc-step.fin{border-color:var(--amber);color:var(--amber);background:var(--amber2);font-weight:700}
.bc-arr{color:var(--text3);font-size:9px}

/* Prob display */
.prob-row{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:12px}
.prob-box{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:10px 12px}
.pb-lbl{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:5px}
.pb-val{font-size:22px;font-weight:700;line-height:1}
.pb-val.green{color:var(--green)}
.pb-val.amber{color:var(--amber)}
.pb-val.blue{color:var(--blue)}
.pb-val.purple{color:var(--purple)}
.pb-sub{font-size:10px;color:var(--text3);margin-top:3px}

/* Correlation / sample size warning */
.warn-box{display:none;background:var(--amber2);border:1px solid rgba(255,184,48,.2);border-radius:3px;padding:8px 12px;margin-bottom:10px;font-size:11px;color:var(--amber);line-height:1.5}
.warn-box.on{display:block}

/* ── Buttons ── */
.btn-row{display:flex;gap:8px;margin-top:1rem}
.btn{padding:10px 16px;border-radius:3px;font-family:var(--mono);font-size:11px;font-weight:700;cursor:pointer;letter-spacing:.08em;text-transform:uppercase;transition:all .15s;border:1px solid}
.btn-green{background:var(--green2);border-color:var(--green);color:var(--green)}
.btn-green:hover{background:rgba(0,224,122,.22)}
.btn-blue{background:var(--blue2);border-color:var(--blue);color:var(--blue)}
.btn-blue:hover{background:rgba(77,171,247,.22)}
.btn-ghost{background:var(--bg2);border-color:var(--border2);color:var(--text2)}
.btn-ghost:hover{border-color:var(--green);color:var(--green)}
.btn:disabled{opacity:.3;cursor:not-allowed}
.btn-full{flex:1}
.btn-sm{padding:6px 12px;font-size:10px}

.status-msg{font-size:11px;color:var(--text3);margin-top:7px;min-height:16px}
.status-msg.err{color:var(--red)}

/* ── Market browser ── */
.browser-row{display:grid;grid-template-columns:1fr auto;gap:8px;align-items:end;margin-bottom:8px}
.mkt-list{display:none;max-height:210px;overflow-y:auto;margin-top:8px}
.mkt-list.on{display:block}
.mkt-item{display:grid;grid-template-columns:1fr auto;align-items:center;gap:8px;padding:8px 10px;border:1px solid var(--border);border-radius:3px;margin-bottom:3px;cursor:pointer;transition:border-color .1s}
.mkt-item:hover{border-color:var(--green)}
.mi-title{font-size:11px;color:var(--text2)}
.mi-ticker{font-size:10px;color:var(--text3);margin-top:1px}
.mi-price{font-size:12px;font-weight:700;color:var(--amber)}

/* ── Loading ── */
.loading{display:none;padding:3rem;text-align:center}
.loading.on{display:block}
.load-bar{width:220px;height:2px;background:var(--border);border-radius:1px;overflow:hidden;margin:0 auto 12px}
.load-fill{height:100%;background:var(--green);animation:sweep 1.6s ease-in-out infinite}
@keyframes sweep{0%{width:0;margin-left:0}50%{width:100%;margin-left:0}100%{width:0;margin-left:100%}}
.load-txt{font-size:11px;color:var(--text3);letter-spacing:.06em}

/* ── Results ── */
.results{display:none}
.results.on{display:block}

.verdict{background:var(--bg1);border:1px solid var(--border);border-radius:6px;padding:1.25rem;margin-bottom:.75rem}
.v-top{display:flex;align-items:center;gap:8px;margin-bottom:10px;flex-wrap:wrap}
.sig{font-family:var(--head);font-size:18px;font-weight:800;padding:5px 20px;border-radius:3px;letter-spacing:.05em}
.sig-buy{background:var(--green2);color:var(--green);border:1px solid rgba(0,224,122,.3)}
.sig-sell{background:var(--red2);color:var(--red);border:1px solid rgba(255,69,96,.3)}
.sig-skip{background:rgba(255,255,255,.04);color:var(--text2);border:1px solid var(--border)}
.badge{font-size:10px;padding:4px 10px;border-radius:2px;border:1px solid var(--border);color:var(--text3);letter-spacing:.06em}
.badge.live{border-color:rgba(0,224,122,.2);color:var(--green);background:var(--green3);display:none}
.badge.live.on{display:inline-block}
.v-text{font-size:13px;color:var(--text);line-height:1.75;font-family:'Syne',sans-serif;font-weight:400}

/* Metrics 6-col */
.metrics{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:7px;margin-bottom:.75rem}
.metric{background:var(--bg1);border:1px solid var(--border);border-radius:4px;padding:11px 12px}
.m-lbl{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:5px}
.m-val{font-size:18px;font-weight:700;line-height:1}
.m-sub{font-size:9px;color:var(--text3);margin-top:3px}
.m-val.green{color:var(--green)}
.m-val.red{color:var(--red)}
.m-val.amber{color:var(--amber)}
.m-val.blue{color:var(--blue)}
.m-val.purple{color:var(--purple)}

/* Detail 2x2 */
.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:.75rem}
.dc{background:var(--bg1);border:1px solid var(--border);border-radius:4px;padding:1rem 1.2rem}
.dc-title{font-size:9px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.12em;margin-bottom:9px;padding-bottom:7px;border-bottom:1px solid var(--border)}
.dr{display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid var(--border);font-size:11px}
.dr:last-of-type{border-bottom:none}
.dl{color:var(--text3)}
.dv{font-weight:500;color:var(--text)}
.dc-text{font-size:12px;color:var(--text2);line-height:1.65;margin-top:8px}
.risk-item{display:flex;gap:7px;padding:3px 0;font-size:12px;color:var(--text2);line-height:1.5}
.rpip{width:4px;height:4px;border-radius:50%;background:var(--text3);margin-top:6px;flex-shrink:0}
.rpip.crit{background:var(--red)}

/* Correlation check */
.corr-section{background:var(--bg1);border:1px solid var(--border);border-radius:4px;padding:1rem 1.2rem;margin-bottom:.75rem}
.corr-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-top:10px}
.corr-item{background:var(--bg2);border:1px solid var(--border);border-radius:3px;padding:8px 10px}
.corr-lbl{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
.corr-val{font-size:12px;color:var(--text)}
.corr-flag{font-size:10px;margin-top:3px}
.corr-flag.warn{color:var(--amber)}
.corr-flag.ok{color:var(--green)}

/* Bottom line */
.bottom-line{background:var(--bg2);border:1px solid var(--border2);border-left:3px solid var(--amber);border-radius:0 3px 3px 0;padding:12px 16px;font-family:var(--head);font-size:14px;font-weight:600;color:var(--amber);line-height:1.5;margin-bottom:.75rem}

/* ── Trade Tracker ── */
.tracker-empty{font-size:11px;color:var(--text3);padding:1rem 0;text-align:center}
.trade-row{display:grid;grid-template-columns:2fr 1fr 1fr 1fr 1fr auto;gap:8px;align-items:center;padding:8px 10px;border:1px solid var(--border);border-radius:3px;margin-bottom:4px;font-size:11px}
.trade-row:hover{border-color:var(--border2)}
.t-market{color:var(--text2)}
.t-sig.buy{color:var(--green)}
.t-sig.sell{color:var(--red)}
.t-sig.skip{color:var(--text3)}
.t-result.win{color:var(--green)}
.t-result.loss{color:var(--red)}
.t-result.open{color:var(--amber)}
.outcome-btn{padding:3px 8px;border-radius:2px;border:1px solid var(--border);background:transparent;color:var(--text3);font-family:var(--mono);font-size:10px;cursor:pointer}
.outcome-btn:hover{border-color:var(--green);color:var(--green)}

/* Stats row */
.stats-row{display:grid;grid-template-columns:repeat(5,1fr);gap:7px;margin-bottom:1rem}
.stat-box{background:var(--bg2);border:1px solid var(--border);border-radius:3px;padding:8px 10px}
.stat-lbl{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
.stat-val{font-size:16px;font-weight:700}
.stat-val.green{color:var(--green)}
.stat-val.red{color:var(--red)}
.stat-val.amber{color:var(--amber)}
.stat-val.blue{color:var(--blue)}

@media(max-width:680px){
  .fg2,.fg3,.fg4{grid-template-columns:1fr}
  .metrics{grid-template-columns:1fr 1fr 1fr}
  .detail-grid{grid-template-columns:1fr}
  .ev-grid{grid-template-columns:1fr}
  .prob-row{grid-template-columns:1fr 1fr}
  .corr-grid{grid-template-columns:1fr}
  .stats-row{grid-template-columns:1fr 1fr}
  .trade-row{grid-template-columns:1fr 1fr}
  .pipe{display:none}
}
</style>
</head>
<body>
<div class="wrap">

<!-- Header -->
<div class="hdr">
  <div class="hdr-left">
    <h1>KALSHI QUANT BOT</h1>
    <p>Base rates · Bayes · EV · Kelly · Correlations · Tracker</p>
  </div>
  <div class="pipe">
    <span class="ps">KALSHI</span><span class="pa">→</span>
    <span class="ps">BACKEND</span><span class="pa">→</span>
    <span class="ps">BOT</span><span class="pa">→</span>
    <span class="ps">YOU</span>
  </div>
</div>

<!-- Tabs -->
<div class="tabs">
  <div class="tab active" onclick="showTab('analyze')">ANALYZE</div>
  <div class="tab" onclick="showTab('tracker')">TRADE TRACKER</div>
  <div class="tab" onclick="showTab('settings')">SETTINGS</div>
</div>

<!-- ════ ANALYZE TAB ════ -->
<div id="tab-analyze">

  <!-- Step 1: Find market -->
  <div class="panel">
    <div class="panel-lbl">Step 1 — Find a live market</div>
    <div class="browser-row">
      <div class="field">
        <label>Browse by series</label>
        <input type="text" id="series-input" placeholder="KXBTCD · KXETHD · KXINXY · KXSPX · KXFED" onkeydown="if(event.key==='Enter')browseMarkets()"/>
      </div>
      <button class="btn btn-ghost btn-sm" onclick="browseMarkets()">FETCH →</button>
    </div>
    <div class="mkt-list" id="mkt-list"></div>

    <div class="fg fg1" style="margin-top:10px">
      <div class="field">
        <label>Ticker (auto-fetches live price + contract details)</label>
        <input type="text" id="market-q" placeholder="e.g. KXBTCD-26MAR1900-T74999.99" oninput="onTickerInput()"/>
      </div>
    </div>
    <div class="adot-row"><div class="adot" id="adot"></div><span id="adot-txt">enter ticker to auto-fetch</span></div>
    <div class="live-prev" id="live-prev">
      <div class="lp-g">
        <div><div class="lp-l">Last price</div><div class="lp-v" id="lp-price">—</div></div>
        <div><div class="lp-l">Yes ask</div><div class="lp-v" id="lp-ask">—</div></div>
        <div><div class="lp-l">Yes bid</div><div class="lp-v" id="lp-bid">—</div></div>
        <div><div class="lp-l">Strike</div><div class="lp-v" id="lp-strike">—</div></div>
      </div>
    </div>
  </div>

  <!-- Step 2: Probability Engine -->
  <div class="prob-engine">
    <div class="pe-hdr">
      <div>
        <div class="pe-title">Step 2 — Probability Estimation Engine</div>
        <div class="pe-sub">Rate each signal → base rate prior → Bayesian updating → model probability</div>
      </div>
      <button class="btn btn-ghost btn-sm" onclick="resetEvidence()">RESET</button>
    </div>

    <!-- Context -->
    <div class="fg fg1" style="margin-bottom:10px">
      <div class="field">
        <label>Market context — describe what you see (price vs strike, news, chart, sentiment)</label>
        <textarea id="ctx" rows="2" placeholder="e.g. BTC at $74,500, testing $75k resistance. FOMC tomorrow March 19. Down 8% past week. Fear index at 28 (extreme fear). Options expiry March 20."></textarea>
      </div>
    </div>

    <!-- Evidence grid -->
    <div class="ev-grid" id="ev-grid">
      <div class="ev-card">
        <div class="ev-card-title">📈 Price momentum</div>
        <div class="ev-row" onclick="tog('mom1')"><div class="ev-tog off" id="tog-mom1">—</div><span class="ev-lbl">Price trending strongly toward strike</span><span class="ev-wt pos">+9%</span></div>
        <div class="ev-row" onclick="tog('mom2')"><div class="ev-tog off" id="tog-mom2">—</div><span class="ev-lbl">Price trending strongly away from strike</span><span class="ev-wt neg">−9%</span></div>
        <div class="ev-row" onclick="tog('mom3')"><div class="ev-tog off" id="tog-mom3">—</div><span class="ev-lbl">Currently within 0.5% of strike (coin flip zone)</span><span class="ev-wt">±0%</span></div>
        <div class="ev-row" onclick="tog('mom4')"><div class="ev-tog off" id="tog-mom4">—</div><span class="ev-lbl">Strong volume confirming direction</span><span class="ev-wt pos">+5%</span></div>
        <div class="ev-row" onclick="tog('mom5')"><div class="ev-tog off" id="tog-mom5">—</div><span class="ev-lbl">Price more than 2% above strike</span><span class="ev-wt pos">+12%</span></div>
        <div class="ev-row" onclick="tog('mom6')"><div class="ev-tog off" id="tog-mom6">—</div><span class="ev-lbl">Price more than 2% below strike</span><span class="ev-wt neg">−12%</span></div>
      </div>

      <div class="ev-card">
        <div class="ev-card-title">⚡ Macro catalyst</div>
        <div class="ev-row" onclick="tog('mac1')"><div class="ev-tog off" id="tog-mac1">—</div><span class="ev-lbl">Major bullish catalyst before resolution</span><span class="ev-wt pos">+8%</span></div>
        <div class="ev-row" onclick="tog('mac2')"><div class="ev-tog off" id="tog-mac2">—</div><span class="ev-lbl">Major bearish catalyst (FOMC, CPI miss)</span><span class="ev-wt neg">−8%</span></div>
        <div class="ev-row" onclick="tog('mac3')"><div class="ev-tog off" id="tog-mac3">—</div><span class="ev-lbl">Options / futures expiry same day</span><span class="ev-wt neg">−4%</span></div>
