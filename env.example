# Proxy security key — set a long random string; frontend must send this as
# x-proxy-api-key header (or ?api_key= query param).
PROXY_API_KEY=make_this_a_long_random_password

# Anthropic key — required for /analyze and Chat tab
ANTHROPIC_API_KEY=sk-ant-...

# Server port (Railway sets this automatically)
PORT=3000

# SQLite database file path
DB_PATH=polymarket.db

# Pipeline tuning (optional — defaults shown)
SNAPSHOT_INTERVAL_SEC=10
REFRESH_INTERVAL_SEC=300
